# FitStream — Environment Variables
# Copy this file to .env and customize for your deployment

# ── API Server ──────────────────────────────────────────
# Host and port for the FastAPI server
FITSTREAM_HOST=0.0.0.0
FITSTREAM_PORT=8000

# ── Security ────────────────────────────────────────────
# CORS: Comma-separated origins (restrict in production!)
FITSTREAM_CORS_ORIGINS=http://localhost:8000,http://localhost:8501

# API Keys: Comma-separated (empty = auth disabled)
# FITSTREAM_API_KEYS=sk-abc123,sk-def456

# ── GPU / Model ─────────────────────────────────────────
# Override default model device (cuda / cpu)
# FITSTREAM_DEVICE=cuda

# Path to downloaded model weights
# FITSTREAM_MODEL_PATH=./models/VACE-Wan2.1-1.3B-Preview

# Real-time weights path (FashionChameleon, when released)
# FITSTREAM_REALTIME_WEIGHTS_PATH=/path/to/fc_weights

# ── Output ─────────────────────────────────────────────
# Directory for generated videos
FITSTREAM_OUTPUT_DIR=./outputs

# ── Rate Limits ────────────────────────────────────────
# Requests per minute per IP (default: 30)
# Generation endpoints per minute per IP (default: 5)
# FITSTREAM_RPM=30
# FITSTREAM_GEN_RPM=5

# ── Job Queue ───────────────────────────────────────────
# Maximum concurrent generation jobs
# FITSTREAM_MAX_CONCURRENT_JOBS=2

# Timeout per job in seconds (default: 600 = 10 min)
# FITSTREAM_JOB_TIMEOUT=600
